# ─────────────────────────────────────────────
#  FixIt App — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/fixit_app
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/fixit_app?retryWrites=true&w=majority

# JWT — CHANGE THIS IN PRODUCTION (min 32 chars)
JWT_SECRET=fixit_super_secret_change_in_production_min32chars

# Admin credentials
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=Admin@123

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# Logging
LOG_LEVEL=info

# SMS Provider (optional — remove demo OTP in production)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
# TWILIO_PHONE=+1xxxxxxxxxx
